{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dcg.dev/schema/graph_data.schema.json",
  "title": "DCG Graph Data",
  "description": "Entity and relation data for a DCG domain knowledge unit graph.",
  "type": "object",
  "required": ["entities", "relations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string" },
    "entities": { "$ref": "#/$defs/entities_map" },
    "relations": { "$ref": "#/$defs/relations_map" }
  },
  "$defs": {
    "entities_map": {
      "type": "object",
      "patternProperties": {
        "^dcg:(sha256:[0-9a-f]{32}|meta:[A-Za-z][A-Za-z0-9_]*)$": {
          "$ref": "#/$defs/entity"
        }
      },
      "additionalProperties": false
    },
    "entity": {
      "oneOf": [
        { "$ref": "#/$defs/entity_full" },
        { "$ref": "#/$defs/entity_retracted" }
      ]
    },
    "entity_full": {
      "type": "object",
      "required": ["id", "label", "description", "attributes"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "attributes": { "type": "array", "items": { "$ref": "#/$defs/attribute" } }
      },
      "patternProperties": { "^dcg:": {} },
      "additionalProperties": false
    },
    "entity_retracted": {
      "type": "object",
      "required": ["id", "retracted"],
      "properties": {
        "id": { "type": "string" },
        "retracted": { "const": true },
        "attributes": { "type": "array", "items": { "$ref": "#/$defs/attribute" } }
      },
      "patternProperties": { "^dcg:": {} },
      "additionalProperties": false
    },
    "attribute": {
      "type": "object",
      "required": ["property"],
      "properties": {
        "property": { "type": "string" },
        "ref": { "type": "string" },
        "string": { "type": "string" },
        "quantity": { "type": "number" },
        "qualifiers": { "type": "array" },
        "retracted": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "relations_map": {
      "type": "object",
      "patternProperties": {
        "^dcg:rel:sha256:[0-9a-f]{32}$": { "$ref": "#/$defs/relation" }
      },
      "additionalProperties": false
    },
    "relation": {
      "type": "object",
      "required": ["dcg:type", "uid", "source", "target", "property"],
      "properties": {
        "dcg:type": { "const": "relation" },
        "uid": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "property": { "type": "string" },
        "qualifiers": { "type": "array" },
        "retracted": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
