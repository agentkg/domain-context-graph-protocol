{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dcg.dev/schema/stack.schema.json",
  "title": "DCG Stack Manifest",
  "description": "Composition manifest for multi-layer DCG knowledge stacks.",
  "type": "object",
  "required": ["stack", "layers"],
  "additionalProperties": false,
  "properties": {
    "stack": { "type": "string" },
    "strict": { "type": "boolean", "default": false },
    "layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/layer_entry" },
      "minItems": 1
    },
    "joins": {
      "type": "array",
      "items": { "$ref": "#/$defs/join_rule" }
    }
  },
  "$defs": {
    "layer_entry": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" },
        "extends": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "join_rule": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*( [a-z][a-z0-9_]*)*$": {
          "type": "string",
          "pattern": "^([a-z][a-z0-9_-]*\\.)?[A-Z][A-Za-z0-9_-]*\\.[a-z][a-z0-9_]* -> ([a-z][a-z0-9_-]*\\.)?[A-Z][A-Za-z0-9_-]*\\.[a-z][a-z0-9_]*$"
        }
      },
      "additionalProperties": false
    }
  }
}
