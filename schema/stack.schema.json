{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dcg.dev/schema/stack.schema.json",
  "title": "DCG Stack Manifest",
  "description": "Composition manifest for multi-layer DCG knowledge stacks.",
  "type": "object",
  "required": ["stack", "layers"],
  "additionalProperties": false,
  "properties": {
    "stack": { "type": "string" },
    "strict": { "type": "boolean", "default": false },
    "layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/layer_entry" },
      "minItems": 1
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge_rule" }
    }
  },
  "$defs": {
    "layer_entry": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" },
        "extends": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pass_type": {
          "type": "string",
          "enum": ["full", "incremental"],
          "default": "full"
        }
      },
      "additionalProperties": false
    },
    "edge_rule": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "patternProperties": {
        "^[a-z_][a-z0-9_ ]*$": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*\\.[a-z_][a-z0-9_]* -> [A-Za-z][A-Za-z0-9_]*\\.[a-z_][a-z0-9_]*$"
        }
      },
      "additionalProperties": false
    }
  }
}
